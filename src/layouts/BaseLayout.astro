---
import "../styles/common.css";
import ToC from '../components/ToC.astro';
import ThemeBtn from '../components/ThemeBtn.astro';
import PrintBtn from '../components/PrintBtn.astro';

const nameFirst = import.meta.env.YOUR_NAME_FIRST;
const nameLast = import.meta.env.YOUR_NAME_LAST;

// This runs once during 'npm run build'
const buildDate = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
});

const { metatitle } = Astro.props;
---
<!--  ::::::::::  ##::    ::## :::::::::::: ##::   ::## -->
<!-- :::::::::::: ##::    ::## :::::::::::: ###::  ::## -->
<!-- ::::::       ##::    ::##     ::::     ####:: ::## -->
<!--  ::::::::::  ############     ::::     ## ::####:: -->
<!--       ::::::: ############     ::::     ##  ::###:: -->
