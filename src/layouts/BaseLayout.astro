---
const { title } = Astro.props;
import "../styles/common.css";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width">
  <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css" />
  <title>{title}</title>
</head>
<body>
  <nav class="max-w-3xl mx-auto p-8 flex justify-between items-center">
    <a href="/" class="font-bold text-xl">Yourae Shin</a>
    <div class="space-x-6">
      <a href="#publications" class="hover:text-blue-600">Publications</a>
      <a href="/cv.pdf" class="hover:text-blue-600">CV</a>
    </div>
  </nav>

  <main class="max-w-3xl mx-auto px-8 pb-20">
    <!-- slot content -->
    <slot />
  </main>

  <footer class="text-center p-10 text-sm text-zinc-400">
    <p>© 2026 Yourae Shin · Built with Astro + Pug</p>
  </footer>
</body>
</html>
