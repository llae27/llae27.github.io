---
import type { HTMLAttributes } from 'astro/types';
interface Props extends HTMLAttributes<'span'> {
  dateStart: string;
  dateEnd: string;
}
const { dateStart, dateEnd, ...attr } = Astro.props;

function formatDate(d) {
  // handle exceptions
  if (!d || typeof d !== 'string') return d;

  const [y, m, day] = d.split('-');
  const dt = new Date(y, m - 1, day);
  if (isNaN(dt.getTime())) return d;

  return dt.toLocaleString('en-US', {
    month: 'short',
    year: 'numeric'
  });
}
---
<div {...attr}>
  <p class="acc1 leading-[1.625rem] print:leading-[1.25rem]">
    <span class="whitespace-nowrap" title={dateStart}>{formatDate(dateStart)}</span>
    {dateEnd ? '-' : ''}
    <span class="whitespace-nowrap" title={dateEnd}>{formatDate(dateEnd)}</span>
  </p>
</div>
