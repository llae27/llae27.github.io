---
import Date from '../components/Date.astro';
const { school, address, admitDate, gradDate = "Current", program, dept } = Astro.props;
---

<li class="sm:grid grid-cols-4 gap-x-2 items-start justify-between mb-2">
  <Date
    dateStart={admitDate}
    dateEnd={gradDate}
  />
  <div class="col-start-2 col-end-5">
    <p class="font-semibold">{program}</p>
    <p class="text-zinc-600 text-sm">{dept}</p>
    <p class="text-zinc-500 text-sm italic">{school}, {address}</p>
    <div>
      <p>Overall GPA</p>
    </div>
  </div>
</li>