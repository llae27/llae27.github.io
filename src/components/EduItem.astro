---
const { school, address, admitDate, gradDate, program, dept  = "#" } = Astro.props;
---

<div class="mb-6 group">
  <div class="flex flex-row items-center justify-between">
    <h3 class="text-lg font-semibold text-zinc-800 group-hover:text-blue-600 transition-colors">
        {program}
    </h3>
    <p class="text-zinc-600 text-sm">{admitDate}-{gradDate}</p>
  </div>
  <p class="text-zinc-600 text-sm">{dept}</p>
  <p class="text-zinc-500 text-sm italic">{school}, {address}</p>
  <div>
    <p>Overall GPA</p>
  </div>
</div>