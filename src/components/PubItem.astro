---
import { Icon } from 'astro-icon/components';
import type { HTMLAttributes } from 'astro/types';
import { Cite } from '@citation-js/core';
import '@citation-js/plugin-bibtex';
import '@citation-js/plugin-csl';

interface Props extends HTMLAttributes<'p'> {
  year: string;
  month: string;
  day: string;
}

const nameFirst = import.meta.env.YOUR_NAME_FIRST;
const nameLast = import.meta.env.YOUR_NAME_LAST;
const yourName = `${nameFirst} ${nameLast}`;
const yourNameRegex = new RegExp(`(${nameLast}, ${nameFirst.slice(0,1)}\\.|${nameFirst.slice(0,1)}\\. ${nameLast})`, 'g');

function formatApa (cite, first = 1) {
  // Output as APA Style HTML
  let count = 0;
  const citeApa = cite.format('bibliography', {
    template: 'apa',
    format: 'html',
    lang: 'en-US'
  }).replace(/\., /g, (match) => {
    count++;
    return count <= first ? ".*, " : match;
  }).replace(yourNameRegex, `<strong>$1</strong>`);
  return citeApa
}

const { title, journal, year, month, day, address, url, externalIds, type, bibtex, award, first = 1 } = Astro.props;

const cite = new Cite(bibtex.replace(/\s+/g, ' ').trim());
const citeApa = formatApa(cite, first);

const dateYear = year || cite.data?.[0]?.issued?.['date-parts']?.[0][0];
const dateMonth = month || cite.data?.[0]?.issued?.['date-parts']?.[0][1];
const date = day ? `${dateYear}-${dateMonth}-${day}` : `${dateYear}-${dateMonth}`;

const authors = cite.data[0].author.map((a, idx) => {
  const name = `${a.given} ${a.family}`;
  const isFirst = idx < first ? '*' : '';
  if (name === yourName) return `<strong>${name}${isFirst}</strong>`;
  else return `${name}${isFirst}`;
}).join(', ');

const venue = type === 'preprint' ? 'Preprint' : journal || cite.data?.[0]?.container-title || `${cite.data?.[0]?.publisher}, ${cite.data?.[0]?.['publisher-place']} (${type})` || '';
---

<li class="sm:flex sm:flex-row-reverse items-start justify-between gap-x-4 mb-el print:list-item print:ml-4 print:mb-space">
  <div class="print:hidden">
    {url && (
      <a href={url} target="_blank">
        <p class="title">{title || cite.data?.[0]?.title}</p>
      </a>
    )}
    {!url && (
      <p class="title">{title || cite.data?.[0]?.title}</p>
    )}
    <p class="acc1" set:html={authors}></p>
    <div class="sm:flex flex-row items-center space-x-2">
      <div class="flex flex-row items-center space-x-2">
        <p class="acc2">{venue}</p>
        <ul class="flex flex-row items-center space-x-2">
          {externalIds?.doi && (
            <li>
              <a href={`${externalIds.doi.url}`} target="_blank">
                <Icon name="doi" />
              </a>
            </li>
          )}
          {externalIds?.pmid && (
            <li>
              <a href={`${externalIds.pmid.url}`} target="_blank">
                <Icon name="pubmed-square" />
              </a>
            </li>
          )}
          {bibtex && (
            <li 
              x-data="{ 
                copied: false, 
                copy() { 
                  navigator.clipboard.writeText($refs.bibContent.innerText);
                  this.copied = true;
                  setTimeout(() => this.copied = false, 2000);
                }
              }"
              title="BibTex"
              class="flex flex-row items-center space-x-1"
            >
              <pre x-ref="bibContent" class="hidden">{bibtex}</pre>
              <a class="cursor-pointer" @click="copy()">
                <Icon
                  x-show="!copied"
                  name="ic:baseline-account-balance"
                />
                <Icon class="text-green-600" x-show="copied" name="ic:baseline-check-circle"/>
              </a>
              <span class="text-green-600 text-sm" x-show="copied">Copied!</span>
            </li>
          )}
        </ul>
      </div>
      {award && (
        <div class="award">
          <Icon name="ic:baseline-emoji-events" />
          <span>{award}</span>
        </div>
      )}
    </div>
  </div>
  <p title={date} class="acc1 leading-[1.625rem] print:hidden">{dateYear}</p>
  <div class="text-sm hidden print:block" set:html={citeApa}></div>
</li>

<style>
  @reference "../styles/common.css";
  @layer base {
    a {@apply hover:underline;}
    svg {
      @apply w-4 h-4 text-zinc-600 dark:text-zinc-500 hover:text-zinc-900 hover:dark:text-zinc-200;
    }
    div.award {@apply flex flex-row items-center space-x-1;}
    div.award > svg {@apply text-yellow-500 dark:text-yellow-600;}
    div.award > span {@apply text-sm text-yellow-500 dark:text-yellow-600;}
  }
</style>