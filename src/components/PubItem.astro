---
import { Icon } from 'astro-icon/components';
import type { HTMLAttributes } from 'astro/types';
interface Props extends HTMLAttributes<'p'> {
  year: string;
  month: string;
  day: string;
}
const { title, authors, journal, year, month, day, venue, address, url, type, externalIds, award, bibtex, citeApa, ...attrs } = Astro.props;
const date = day ? `${year}-${month}-${day}` : `${year}-${month}`;
---

<li class="sm:flex sm:flex-row items-start justify-between gap-x-4 mb-el print:list-item print:ml-4 print:mb-space">
  <div class="print:hidden">
    {url && (
      <a href={url} target="_blank">
        <p class="title">{title}</p>
      </a>
    )}
    {!url && (
      <p class="title">{title}</p>
    )}
    <p class="acc1" set:html={authors}></p>
    <div class="sm:flex flex-row items-center space-x-2">
      <div class="flex flex-row items-center space-x-2">
        <p class="acc2">
          {journal}
          {type === 'preprint' && ('Preprint')}
          {venue && (`${venue}, ${address} (${type})`)}
        </p>
        <ul class="flex flex-row items-center space-x-2">
          {externalIds?.doi && (
            <li>
              <a href={`${externalIds.doi.url}`} target="_blank">
                <Icon name="doi" />
              </a>
            </li>
          )}
          {externalIds?.pmid && (
            <li>
              <a href={`${externalIds.pmid.url}`} target="_blank">
                <Icon name="pubmed-square" />
              </a>
            </li>
          )}
          {bibtex && (
            <li 
              x-data="{ 
                copied: false, 
                copy() { 
                  navigator.clipboard.writeText($refs.bibContent.innerText);
                  this.copied = true;
                  setTimeout(() => this.copied = false, 2000);
                }
              }"
              title="BibTex"
              class="flex flex-row items-center space-x-1"
            >
              <pre x-ref="bibContent" class="hidden">{bibtex}</pre>
              <a class="cursor-pointer" @click="copy()">
                <Icon
                  x-show="!copied"
                  name="ic:baseline-account-balance"
                />
                <Icon class="text-green-600" x-show="copied" name="ic:baseline-check-circle"/>
              </a>
              <span class="text-green-600 text-sm" x-show="copied">Copied!</span>
            </li>
          )}
        </ul>
      </div>
      {award && (
        <div class="award">
          <Icon name="ic:baseline-emoji-events" />
          <span>{award}</span>
        </div>
      )}
    </div>
  </div>
  <p title={date} class="acc1 print:hidden">{year}</p>
  <div class="text-sm hidden print:block" set:html={citeApa}></div>
</li>

<style>
  @reference "../styles/common.css";
  @layer base {
    a {@apply hover:underline;}
    svg {
      @apply w-4 h-4 text-zinc-600 dark:text-zinc-500 hover:text-zinc-900 hover:dark:text-zinc-200;
    }
    div.award {@apply flex flex-row items-center space-x-1 text-yellow-500;}
    div.award > svg {@apply text-yellow-500 dark:text-yellow-600;}
    div.award > span {@apply text-sm text-yellow-500 dark:text-yellow-600;}
  }
</style>